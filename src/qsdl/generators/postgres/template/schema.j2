{%- macro build_column(column) -%}
{{- column.type -}}
{{- " []" if column.is_array -}}
{{- " NOT NULL" if column.is_required -}}
{{- " UNIQUE" if column.is_unique -}}
{{- column.enum if column.enum -}}
{%- endmacro -%}


{% for table in tables %}
{% set filtered_columns = table.columns | selectattr("is_id", "equalto", False) | list %}
CREATE TABLE IF NOT EXISTS {{table.name}} (
  {% if not table.is_jointable %}
  id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
  uid VARCHAR UNIQUE,
  iv INTEGER{{ "," if filtered_columns }}
  {% endif %}
  {% for column in filtered_columns %}
  {{column.name}} {{build_column(column)}}{{ "," if not loop.last or table.is_jointable }}
  {% endfor %}
  {% if table.is_jointable %}
  PRIMARY KEY ({{filtered_columns[0].name}}, {{filtered_columns[1].name}})
  {% endif %}
);

{% endfor %}

{%- for table in tables %}
  {% for constr in table.constraints %}
{{constr}}
  {% endfor %}
{% endfor %}