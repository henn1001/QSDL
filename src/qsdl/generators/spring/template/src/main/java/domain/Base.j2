{% import '_macro/Util.j2' as util with context %}
{% set has_date = model.fields|selectattr("is_date") | list %}
{% set has_array = model.fields|selectattr("is_array")|rejectattr("is_relation") | list %}
/**
 * NOTE: This record was generated by QSDL.
 */
package {{model.package.domain}};

{{ util.macro_imports(self._TemplateReference__context.name, model) }}

@RecordBuilder
public record {{model.name}}(
// @formatter:off
{% for field in model.fields if not field.is_relation and not field.is_hidden and not field.is_write_only %}

    {# 
        Set @Valid for any container
    #}
    {% if (field.is_array or field.is_base or field.is_object) %}
    @Valid
    {% endif %}
    {# 
        Size limits
    #}
    {% if field.type == "String" %}
    @Size(min = {{field.min_size}}, max = {{field.max_size}})
    {% endif %}
    {% if field.type in ["Integer", "Long"] and field.min_size and not field.is_array %}
    @Min({{field.min_size}})
    @Max({{field.max_size}})
    {% endif %}
    {# 
        Pattern
    #}
    {% if field.pattern and not field.is_array    %}
    @Pattern(regexp = "{{field.pattern}}")
    {% endif %}
    {# 
        Set JsonProperty annotation - no required flag needed for responses
    #}
    @JsonProperty(value = "{{field.json_key}}")
    {# 
        Set the Field definition
    #}
    {% if field.is_array %}
    List<{{ "@Pattern(regexp = \"" + field.pattern + "\") " if field.pattern}}{{field.type}}> {{field.name}}{{ "," if not loop.last else "" }}
    {% else %}
    {{field.type}} {{field.name}}{{ "," if not loop.last else "" }}
    {% endif %}
{% endfor %}
) {
}
