        if (!errors.isEmpty()) {
            throw new AppException(ErrorCode.BAD_REQUEST, errors);
        }
    }

    public static final <E extends Enum<E>> void validateEnum(String key, String value, Class<E> enumClass)
            throws AppException {
        E[] enumConstants = enumClass.getEnumConstants();

