{# 
    Returns a class identifier.
#}
{% macro attribute_annotation(field) -%}
    {#
        Serialization for objects
    #}
    {% if field.type == "ObjectNode" %}
    @JdbcTypeCode(SqlTypes.JSON)
    {% endif %}
    {#
        Uniqueness
    #}
    {% if field.is_unique %}
    @Column(unique = true)
    {% endif %}
    {#
        Serialization for Enums
    #}
    {% if field.is_enum %}
    @Enumerated(EnumType.STRING)
    {% endif %}
    {#
        Relations: Both @composition and @aggregation now use join tables for arrays
        (matching PostgreSQL generator behavior)
    #}
    {% if field.is_relation and not field.is_relation_owner %}
            {#
                Non-owner side: uses mappedBy to reference the owning side
                For @aggregation: target has plural field name (e.g., "projects")
                For @composition: target has singular field name (e.g., "project")
            #}
            {% if field.is_array %}
    @ManyToMany(mappedBy = "{{model.name|lower}}{{ 's' if field.is_aggregation else '' }}", fetch = FetchType.LAZY{{ ", cascade = CascadeType.ALL" if field.is_composition else "" }})
            {% else %}
    @OneToOne(mappedBy = "{{model.name|lower}}", fetch = FetchType.LAZY{{ ", cascade = CascadeType.ALL" if field.is_composition else "" }})
            {% endif %}
    {% elif field.is_relation and field.is_relation_owner %}
            {#
                Owner side (synthetic field created by _add_foreign_keys)
                Uses @JoinTable matching PostgreSQL: t_{parent}_{original_field}_to_t_{child}
                field.type = parent type, field.foreign_key_name = original field name, model.name = child type
            #}
            {% if field.is_array %}
                {# Aggregation: Parent has array, child gets plural back-reference #}
    @ManyToMany(fetch = FetchType.LAZY)
    @JoinTable(name = "{{table_prefix}}{{field.type|snake}}_{{field.foreign_key_name|snake}}_to_{{table_prefix}}{{model.name|snake}}", joinColumns = @JoinColumn(name = "{{model.name|snake}}_id"), inverseJoinColumns = @JoinColumn(name = "{{field.type|snake}}_id"))
            {% else %}
                {# Composition: Parent has array, child gets singular back-reference #}
    @ManyToMany(fetch = FetchType.LAZY, cascade = CascadeType.ALL)
    @JoinTable(name = "{{table_prefix}}{{field.type|snake}}_{{field.foreign_key_name|snake}}_to_{{table_prefix}}{{model.name|snake}}", joinColumns = @JoinColumn(name = "{{model.name|snake}}_id"), inverseJoinColumns = @JoinColumn(name = "{{field.type|snake}}_id"))
            {% endif %}
    {#
        Base Types with @opaque: JSONB storage
    #}
    {% elif field.is_base and field.is_opaque and not field.is_array %}
    @JdbcTypeCode(SqlTypes.JSON)
    @Column(name = "{{field.name|snake}}")
    {% elif field.is_base and field.is_opaque and field.is_array %}
    @JdbcTypeCode(SqlTypes.JSON)
    @Column(name = "{{field.name|snake}}")
    {#
        Base Types without @opaque: No Hibernate annotation (fields are flattened inline)
    #}
    {% elif field.is_base and not field.is_opaque and not field.is_array %}
    {# No annotation needed - fields are expanded inline in Entity.j2 #}
    {#
        Non-relation Object arrays: Use @JoinTable (matching PostgreSQL)
        Non-relation Base arrays: Already handled above (JSONB for @opaque, flattened otherwise)
    #}
    {% elif field.is_array and field.is_object %}
    @ManyToMany(cascade = CascadeType.ALL)
    @JoinTable(name = "{{table_prefix}}{{model.name|snake}}_{{field.name|snake}}_to_{{table_prefix}}{{field.type|snake}}", joinColumns = @JoinColumn(name = "{{model.name|snake}}_id"), inverseJoinColumns = @JoinColumn(name = "{{field.type|snake}}_id"))
    {% elif not field.is_array and field.is_object %}
    @OneToOne(cascade = CascadeType.ALL, orphanRemoval = true)
    @JoinColumn(name = "{{field.name|snake}}_{{field.type|snake}}_id")
    {% elif field.is_array %}
    @ElementCollection
    @CollectionTable(name="{{table_prefix}}{{model.name|lower}}_to_{{field.type|lower|lower}}")
    {% endif %}
{% endmacro %}
