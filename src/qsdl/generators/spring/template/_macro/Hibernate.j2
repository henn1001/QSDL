{# 
    Returns a class identifier.
#}
{% macro attribute_annotation(field) -%}
    {#
        Serialization for objects
    #}
    {% if field.type == "ObjectNode" %}
    @JdbcTypeCode(SqlTypes.JSON)
    {% endif %}
    {#
        Uniqueness
    #}
    {% if field.is_unique %}
    @Column(unique = true)
    {% endif %}
    {#
        Serialization for Enums
    #}
    {% if field.is_enum %}
    @Enumerated(EnumType.STRING)
    {% endif %}
    {#
        Relations
    #}
    {% if field.is_relation and not field.is_relation_owner %}
            {# 
                the parent side of the relation.
            #}
            {% if field.is_aggregation and field.is_array %}
    @ManyToMany(mappedBy = "{{model.name|lower}}s", fetch = FetchType.LAZY)
            {% elif field.is_aggregation and not field.is_array %}
    @OneToMany(mappedBy = "{{model.name|lower}}s", fetch = FetchType.LAZY)
            {% elif field.is_composition and field.is_array %}
    @OneToMany(mappedBy = "{{model.name|lower}}", fetch = FetchType.LAZY, cascade = CascadeType.ALL)
            {% elif field.is_composition and not field.is_array %}
    @OneToOne(mappedBy = "{{model.name|lower}}", fetch = FetchType.LAZY, cascade = CascadeType.ALL)
            {% endif %}
    {% elif field.is_relation and field.is_relation_owner %}
            {#
                The child/owning side of the relation.
            #}
            {% if field.is_aggregation and field.foreign_key_is_array %}
    @ManyToMany(fetch = FetchType.LAZY)
    @JoinTable(name = "{{table_prefix}}{{field.type|lower}}_to_{{model.name|lower}}", joinColumns = @JoinColumn(name = "{{model.name|lower}}_id"), inverseJoinColumns = @JoinColumn(name = "{{field.type|lower}}_id"))
            {% elif field.is_aggregation and not field.foreign_key_is_array    %}
    @ManyToOne(fetch = FetchType.LAZY)
    @JoinColumn(name = "{{field.type|lower}}_id")
            {% elif field.is_composition and field.foreign_key_is_array %}
    @ManyToOne(fetch = FetchType.LAZY)
    @JoinColumn(name = "{{field.type|lower}}_id")
            {% elif field.is_composition and not field.foreign_key_is_array %}
    @OneToOne(fetch = FetchType.LAZY)
    @JoinColumn(name = "{{field.type|lower}}_id")
            {% endif %}
    {#
        Base Types: New semantics for @opaque directive
    #}
    {% elif field.is_base and not field.is_array and field.is_opaque %}
    @JdbcTypeCode(SqlTypes.JSON)
    @Column(name = "{{field.name|snake}}", columnDefinition = "jsonb")
    {% elif field.is_base and not field.is_array and not field.is_opaque %}
    @Embedded
    @AttributeOverrides({
    {% for base_field in field.base_fields %}
        @AttributeOverride(name = "{{base_field.name}}", column = @Column(name = "{{field.name|snake}}_{{base_field.name|snake}}")){{ "," if not loop.last }}
    {% endfor %}
    })
    {% elif field.is_base and field.is_array and field.is_opaque %}
    @JdbcTypeCode(SqlTypes.JSON)
    @Column(name = "{{field.name|snake}}", columnDefinition = "jsonb")
    {#
        Nested Objects: Keep existing behavior for Objects
    #}
    {% elif field.is_array and field.is_object %}
    @OneToMany(cascade = CascadeType.ALL, orphanRemoval = true)
    @JoinColumn(name = "{{field.name|snake}}_{{model.name|snake}}_id")
    {% elif field.is_array and field.is_base %}
    @OneToMany(cascade = CascadeType.ALL, orphanRemoval = true)
    @JoinColumn(name = "{{field.name|snake}}_{{model.name|snake}}_id")
    {% elif not field.is_array and field.is_object %}
    @OneToOne(cascade = CascadeType.ALL, orphanRemoval = true)
    @JoinColumn(name = "{{field.name|snake}}_{{field.type|snake}}_id")
    {% elif field.is_array %}
    @ElementCollection
    @CollectionTable(name="{{table_prefix}}{{model.name|lower}}_to_{{field.type|lower|lower}}")
    {% endif %}
{% endmacro %}
