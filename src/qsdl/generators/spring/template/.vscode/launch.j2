{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Run Dev",
      "request": "launch",
      "mainClass": "{{base_package}}.SpringBootApp",
      "projectName": "{{artifact_id}}",
      "args": [
        "--spring.profiles.active=dev"
      ]
    },
    {
      "type": "java",
      "name": "Run Local",
      "request": "launch",
      "mainClass": "{{base_package}}.SpringBootApp",
      "projectName": "{{artifact_id}}",
      "args": [
        "--spring.profiles.active=local"
      ]
    },
    {
      "type": "java",
      "name": "Run Production",
      "request": "launch",
      "mainClass": "{{base_package}}.SpringBootApp",
      "projectName": "{{artifact_id}}",
      "args": [
        "--spring.profiles.active=prod"
      ]
    },
    {
      "type": "java",
      "name": "Create Schema",
      "request": "launch",
      "mainClass": "{{base_package}}.SpringBootApp",
      "projectName": "{{artifact_id}}",
      "args": [
        "--spring.profiles.active=prod-init"
      ]
    },
  ]
}