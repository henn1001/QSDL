name: {{artifact_id}}

services:
  service:
    image: maven:3.9-eclipse-temurin-21
    command:
      - mvn
      - spring-boot:run
      - -Dspring-boot.run.profiles=prod
    ports:
      - 8080:8080
      - 8081:8081
    volumes:
      - ./:/usr/src/mymaven:rw
      - m2data:/root/.m2/repository
    working_dir: /usr/src/mymaven
    depends_on:
      - db
  db:
    image: postgres:16
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: postgres
    ports:
      - 5432:5432

volumes:
  m2data:

{{""}}