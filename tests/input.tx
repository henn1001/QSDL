title: "Test API"
version: "1.0"
description: """
This example should test every option of this generator.
"""

servers: ["https://localhost:8080/api/v1", "https://localhost:8082/api/v1"]

enum Status {
    OPEN
    TO_DO
    CLOSED
}

base Rating {
    user: User
    scores: [Float]
}

base Metric {
    likes: Int
    ratings: [Rating] @nested
}

base BaseType {
    id: ID! @readOnly
    name: String! @query
    "Optional description"
    description: String
    creation_by: String @readOnly
    creation_date: Date @readOnly
    last_update_by: String @readOnly
    last_update_date: Date @readOnly
    """ 
    Accepts any valid json object.
    """
    meta_inf: Object
}


// NameSpace Management
""" 
Test multiline description for objects
"""
type Project implements BaseType @namespace(value="Management") {
    "Archive this Project"
    archive: Boolean @writeOnly
    """ 
    A nested metrics object.
    """
    metrics: [Metric] @nested
    tickets: [Ticket] @composition
    roles: [Role] @composition
    milestones: [Milestone] @composition
}

"Test singleline description for objects"
type Role @namespace(value="Management"){
    role: ID!
    users: [User] @aggregation @nested
}

type User @namespace(value="Management"){
    name: ID! @query
    full_name: String
    emails: [String]
    password: String
}


// NameSpace Incident
    type Ticket @namespace(value="Incident"){
        number: ID!
        title: String
        issuer: User
        issuer_body: User @nested @readOnly
        body: String
        status: Status
        milestones: [Milestone] @aggregation
    }

    type Milestone @namespace(value="Incident"){
        milestone: ID!
        sprints: [Sprint] @composition
    }

    type Sprint @namespace(value="Incident"){
        name: ID!
        roles: [Role] @composition @nested
    }

    "To test object without a ID"
    type Buzzword @namespace(value="Incident"){
        id: ID!
        name: String!
        test: QueryMachine @composition

        extend Operation {
            getBuzzword(id: ID!): Buzzword
            getBuzzwords(name: String): [Buzzword]
            createBuzzword(body: Buzzword): Buzzword @post
            updateBuzzword(id: ID!, body: String, test: [Boolean]): Buzzword @put
            deleteBuzzword(id: ID!): Void @delete
        }
    }

    "To test custom paths"
    type QueryMachine @namespace(value="Incident"){
        request: String! @writeOnly
        response: Object @readOnly

         extend Operation {
            "something"
            submitQuery(body: QueryMachine): QueryMachine @path(value="query/submit") @post
        }
    }

extend Operation {
    "something else"
    submitQury(body: QueryMachine): QueryMachine @path(value="query/submits") @post
}