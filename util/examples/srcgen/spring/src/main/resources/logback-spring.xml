<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <property name="LOGS" value="logs" />

  <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
    <layout class="ch.qos.logback.classic.PatternLayout">
      <Pattern>%d{yyyy-MM-dd} | %d{HH:mm:ss.SSS} | %highlight(%-5level) | %magenta(%-15.15thread) | %-20.20(%logger{5}) | %m%n</Pattern>
    </layout>
  </appender>

  <appender name="RollingFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <Pattern>%d{yyyy-MM-dd} | %d{HH:mm:ss.SSS} | %-5level | %-15.15thread | %-20.20(%logger{5}) | %m%n</Pattern>
    </encoder>

    <file>${LOGS}/spring.log</file>

    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <!-- weekly rollover and keep maximum 30 days -->
      <fileNamePattern>${LOGS}/archived/spring.%d{yyyy-MM-dd}.log</fileNamePattern>
      <maxHistory>30</maxHistory>
    </rollingPolicy>
  </appender>

  <!-- LOG everything at INFO level -->
  <root level="info">
    <appender-ref ref="RollingFile" />
    <appender-ref ref="Console" />
  </root>

</configuration>