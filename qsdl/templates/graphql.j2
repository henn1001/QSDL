{% import 'graphql.macro.j2' as macro with context %}
scalar Date
scalar Void
scalar Object

type Query {
    _empty: String
}

type Mutation {
    _empty: String
}

interface Response {
  code: String!
  success: Boolean!
  message: String!
  details: String
}

{# Start drawing loop#}
{% for type in model.types %}
{{ macro.render_loop(type) }}
{% endfor %}

schema{
    query: Query,
    mutation: Mutation
}
