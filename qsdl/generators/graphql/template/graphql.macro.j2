{################################################################}
{% macro render_scalar(scalar) %}
scalar {{scalar.name}}
{% endmacro %}

{################################################################}
{% macro render_enum(enum) %}
{% if enum.description %}
{{ enum.description }}
{% endif %}
enum {{enum.name}} {
    {% for value in enum.values %}
    {{value}}
    {% endfor %}
}
{% endmacro %}

{################################################################}
{% macro render_base(base) %}
{% if base.description %}
{{ base.description }}
{% endif %}
interface {{base.name}} {
    {{ render_fields(base) | indent(2) | trim }}
}
{% if util.is_nested(base) %}

input {{base.name}}Input {
    {{ render_input(base) | indent(2) | trim }}
}
{% endif %}
{% endmacro %}

{################################################################}
{% macro render_object(object) %}
# begin object {{ object.name }} 
{% if object.description %}
{{ object.description }}
{% endif %}
type {{object.name}} {% if object.supertype %}implements {{object.supertype.name}} {% endif %}{
    {{ render_fields(object, filter_wo=True) | indent(2) | trim }}
}

type {{object.name}}List {
    items: [{{object.name}}]!
    next_cursor: String
    total_count: Int
}
{% if util.is_nested(object) %}

input {{object.name}}Input {
    {{ render_input(object) | indent(2) | trim }}
}
{% endif %}
{% if util.get_operations_of_object_of_queries(object) %}

extend type Query {
    {% for operation in util.get_operations_of_object_of_queries(object) %}
    {% if operation.description %}
    {{ operation.description }}
    {% endif %}
    {{ operation.name -}}
        {{ render_arguments(operation) | trim -}}
      {% if operation.response %}: {{ render_response(operation) | trim }}
      {% else %}: Void
      {% endif %}
    {% endfor %}
}
{% endif %}
{% if util.get_operations_of_object_of_mutations(object) %}

extend type Mutation {
  {% for operation in util.get_operations_of_object_of_mutations(object) %}
    {% if operation.description %}
    {{ operation.description }}
    {% endif %}
    {{ operation.name -}}
        {{ render_arguments(operation) | trim -}}: {{ operation.name }}Payload
  {% endfor %}
}
  {% for operation in util.get_operations_of_object_of_mutations(object) if operation.request %}

input {{ operation.name }}Input {
    {% for parameter in operation.request %}
      {% if loop.length == 1 and parameter._tx_fqn in ["entity.Object", "entity.Base"] %}
    {{ render_input(object) | indent(2) | trim }}
      {% elif parameter.value._tx_fqn in ["entity.Object", "entity.Base"] %}
    {{ render_input(parameter.value) | indent(2) | trim }}
      {% else %}
    {{ render_field(parameter) | indent(2) | trim }}
      {% endif %}
    {% endfor %}
}
  {% endfor %}
  {% for operation in util.get_operations_of_object_of_mutations(object) %}

type {{ operation.name }}Payload implements Response {
    code: String!
    success: Boolean!
    message: String!
    details: String
    {% if operation.response %}
    response: {{ render_response(operation) }}
    {% endif %}
}
  {% endfor %}
{% endif %}
# end object {{ object.name }}
{% endmacro %}


{################################################################}
{% macro render_operation(object) %}
{% if util.get_queries_of_operation(object) %}

extend type Query {
    {% for operation in util.get_queries_of_operation(object) %}
    {% if operation.description %}
    {{ operation.description }}
    {% endif %}
    {{ operation.name -}}
        {{ render_arguments(operation) | trim -}}
      {% if operation.response %}: {{ render_response(operation) | trim }}
      {% else %}: Void
      {% endif %}
    {% endfor %}
}
{% endif %}
{% if util.get_mutations_of_operation(object) %}

extend type Mutation {
  {% for operation in util.get_mutations_of_operation(object) %}
    {% if operation.description %}
    {{ operation.description }}
    {% endif %}
    {{ operation.name -}}
        {{ render_arguments(operation) | trim -}}: {{ operation.name }}Payload
  {% endfor %}
}
  {% for operation in util.get_mutations_of_operation(object) if operation.request %}

input {{ operation.name }}Input {
    {% for parameter in operation.request %}
      {% if loop.length == 1 and parameter._tx_fqn in ["entity.Object", "entity.Base"] %}
    {{ render_input(object) | indent(2) | trim }}
      {% elif parameter.value._tx_fqn in ["entity.Object", "entity.Base"] %}
    {{ render_input(parameter.value) | indent(2) | trim }}
      {% else %}
    {{ render_field(parameter) | indent(2) | trim }}
      {% endif %}
    {% endfor %}
}
  {% endfor %}
  {% for operation in util.get_mutations_of_operation(object) %}

type {{ operation.name }}Payload implements Response {
    code: String!
    success: Boolean!
    message: String!
    details: String
    {% if operation.response %}
    response: {{ render_response(operation) }}
    {% endif %}
}
  {% endfor %}
{% endif %}

{% endmacro %}

{################################################################}
{% macro render_loop(type) %}
{% if type._tx_fqn == "entity.Scalar" %}{{ render_scalar(type) | trim }}{% endif %}
{% if type._tx_fqn == "entity.Enum" %}{{ render_enum(type) | trim }}{% endif %}
{% if type._tx_fqn == "entity.Base" %}{{ render_base(type) | trim }}{% endif %}
{% if type._tx_fqn == "entity.Object" %}{{ render_object(type) | trim }}{% endif %}
{% if type._tx_fqn == "entity.Operation" %}{{ render_operation(type) | trim }}{% endif %}

{% endmacro %}


{################################################################}
{% macro render_arguments(operation) %}
{% if operation.parameters or operation.request %}
(
  {%- for parameter in operation.parameters -%}
      {% if parameter.type.value._tx_fqn in ["entity.Object", "entity.Base"] -%}
    {{ parameter.name }}:{{ " " -}}
    {% if parameter.type.array %}{{ "[" }}{% endif -%}
    {{ parameter.type.value.name }}Input{{ "" -}}
    {{ "!" if parameter.required == "true" -}}
    {% if parameter.type.array %}{{ "]" }}{% endif -%}
      {% else -%}
    {{ parameter.name }}:{{ " " -}}
    {% if parameter.type.array %}{{ "[" }}{% endif -%}
    {{ parameter.type.value.name -}}
    {{ "!" if parameter.required == "true" -}}
    {% if parameter.type.array %}{{ "]" }}{% endif -%}
      {% endif -%}
    {{ ", " if not loop.last or operation.request -}}
  {% endfor %}
  {% if operation.request -%}
    input:{{ " " -}}
    {% if operation.request[0].array %}{{ "[" }}{% endif -%}
    {{ operation.name }}Input{{ "" -}}
    {% if operation.request[0].array %}{{ "]" }}{% endif -%}
    {{ "!" -}}
  {% endif %}
)
{% endif %}
{% endmacro %}

{################################################################}
{% macro render_response(operation) %}
{% set field = operation.response  %}
  {% if field.array %}{{ "[" }}{% endif -%}
  {{ field.value.name -}}{% if field.paging %}List{% endif -%}
  {% if field.array %}{{ "]" }}{% endif -%}
{% endmacro %}

{################################################################}
{% macro render_input(entity) %}
{% for field in util.get_fields_as_list(entity) if not field.readonly and  util.get_filtered_fields(field)  %}
 {% if field.value._tx_fqn in ["entity.Object", "entity.Base"] %}
  {{ field.name }}:{{ " " -}}
  {% if field.array %}{{ "[" }}{% endif -%}
  {% if not field.nested and not field.composition and not field.aggregation -%}
  ID{{ "" -}}
  {% else -%}
  {{ field.value.name }}Input{{ "" -}}
  {% endif %}
  {% if field.non_nullable_array %}{{ "!" }}{% endif -%}
  {% if field.array %}{{ "]" }}{% endif -%}
  {% if field.non_nullable %}{{ "!" }}{% endif %}
 {% else %}
  {{ field.name }}:{{ " " -}}
  {% if field.array %}{{ "[" }}{% endif -%}
  {{ field.value.name -}}
  {% if field.non_nullable_array %}{{ "!" }}{% endif -%}
  {% if field.array %}{{ "]" }}{% endif -%}
  {% if field.non_nullable %}{{ "!" }}{% endif %}
 {% endif %}

{% endfor %}
{% endmacro %}

{################################################################}
{% macro render_fields(entity, filter_ro=False, filter_wo=False, filter_objects=False) %}
{% for field in util.get_fields_as_list(entity) if field.readonly == (field.readonly if not filter_ro else False) and field.writeonly == (field.writeonly if not filter_wo else False) %}
  {% if field.description %}
  {{ field.description }}
  {% endif %}
  {{field.name}}:{{ " " -}}
  {% if field.array %}{{ "[" }}{% endif -%}
  {{ field.value.name -}}
  {% if field.non_nullable_array %}{{ "!" }}{% endif -%}
  {% if field.array %}{{ "]" }}{% endif -%}
  {% if field.non_nullable %}{{ "!" }}{% endif %}

{% endfor %}
{% endmacro %}

{################################################################}
{% macro render_field(field, filter_ro=False, filter_wo=False) %}
{% if field.readonly == (field.readonly if not filter_ro else False) and field.writeonly == (field.writeonly if not filter_wo else False) %}
  {{field.name}}:{{ " " -}}
  {% if field.array %}{{ "[" }}{% endif -%}
  {{ field.value.name -}}
  {% if field.non_nullable_array %}{{ "!" }}{% endif -%}
  {% if field.array %}{{ "]" }}{% endif -%}
  {% if field.non_nullable %}{{ "!" }}{% endif %}

{% endif %}
{% endmacro %}

