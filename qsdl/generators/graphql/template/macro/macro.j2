{################################################################}
{% macro render_arguments(operation) %}
{% if operation.arguments or operation.is_pageable %}
(
  {%- for parameter in operation.arguments -%}
    {% if parameter.value._tx_fqn in ["entity.Object", "entity.Base"] -%}
      {{ parameter.name }}:{{ " " -}}
      {{ "[" if parameter.array -}}
      {{ parameter.value.name }}Input{{ "" -}}
      {{ "!" -}}
      {{ "]" if parameter.array -}}
    {% else -%}
      {{ parameter.name }}:{{ " " -}}
      {{ "[" if parameter.array -}}
      {{ parameter.value.name -}}
      {{ "!" if parameter.non_nullable -}}
      {{ "]" if parameter.array -}}
    {% endif -%}
    {{ ", " if not loop.last -}}
  {% endfor %}
  {% if operation.is_pageable -%}
    {% if operation.arguments %}{{", "}}{% endif %}pageable: Pageable{{ "" -}}
  {% endif %}
)
{% endif %}
{% endmacro %}

{################################################################}
{% macro render_response(operation) %}
{% set field = operation  %}
  {% if field.array %}{{ "[" }}{% endif -%}
  {{ field.value.name -}}{% if field.is_pageable %}List{% endif -%}
  {% if field.array %}{{ "]" }}{% endif -%}
{% endmacro %}

{################################################################}
{% macro render_input(entity) %}
{% for field in util.get_fields_as_list(entity) if not field.readonly and util.get_filtered_fields(field) %}
 {% if field.value._tx_fqn in ["entity.Object", "entity.Base"] %}
  {{ field.name }}:{{ " " -}}
  {% if field.array %}{{ "[" }}{% endif -%}
  {% if not field.nested and not field.composition and not field.aggregation -%}
  ID{{ "" -}}
  {% else -%}
  {{ field.value.name }}Input{{ "" -}}
  {% endif %}
  {% if field.array %}{{ "]" }}{% endif -%}
  {% if field.non_nullable %}{{ "!" }}{% endif %}
 {% else %}
  {{ field.name }}:{{ " " -}}
  {% if field.array %}{{ "[" }}{% endif -%}
  {{ field.value.name -}}
  {% if field.array %}{{ "]" }}{% endif -%}
  {% if field.non_nullable %}{{ "!" }}{% endif %}
 {% endif %}

{% endfor %}
{% endmacro %}

{################################################################}
{% macro render_fields(entity, filter_ro=False, filter_wo=False, filter_objects=False) %}
{% for field in util.get_fields_as_list(entity) if field.readonly == (field.readonly if not filter_ro else False) and field.writeonly == (field.writeonly if not filter_wo else False) %}
  {% if field.description %}
  {{ field.description }}
  {% endif %}
  {{field.name}}:{{ " " -}}
  {% if field.array %}{{ "[" }}{% endif -%}
  {{ field.value.name -}}
  {% if field.array %}{{ "]" }}{% endif -%}
  {% if field.non_nullable %}{{ "!" }}{% endif %}

{% endfor %}
{% endmacro %}

{################################################################}
{% macro render_field(field, filter_ro=False, filter_wo=False) %}
{% if field.readonly == (field.readonly if not filter_ro else False) and field.writeonly == (field.writeonly if not filter_wo else False) %}
  {{field.name}}:{{ " " -}}
  {% if field.array %}{{ "[" }}{% endif -%}
  {{ field.value.name -}}
  {% if field.array %}{{ "]" }}{% endif -%}
  {% if field.non_nullable %}{{ "!" }}{% endif %}

{% endif %}
{% endmacro %}