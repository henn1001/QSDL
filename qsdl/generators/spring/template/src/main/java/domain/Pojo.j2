package {{base_package}}.domain;

{% for imp in model.imports %}
import {{imp}};
{% endfor %}
{% if encapsulation %}
import lombok.Getter;
import lombok.Setter;
{% endif %}

{% if model.is_object %}
import {{base_package}}.model.AbstractPersistentObject;
{% endif %}
import {{base_package}}.util.Json;

{% if model.is_enum %}
{% include "Enum.j2" with context %}
{% else %}
{{ "@Getter @Setter" + "\n" if encapsulation -}}
{{ hibernate.class_annotation() if database == "hibernate" -}}
public class {{model.name}}{% if not model.is_base %} extends AbstractPersistentObject{% endif %} {

{% for field in model.fields if not field.is_id %}
  {# 
    Required fields
  #}
  {% if field.is_required and not field.is_read_only%}
  @NotNull
  {% endif %}
  {# 
    Set @Valid for any container
  #}
  {% if (field.is_array or field.is_base or field.is_object) and not field.is_relation %}
  @Valid
  {% endif %}
  {# 
    Hibernate
  #}
  {{- hibernate.attribute_annotation(field) if database == "hibernate" -}}
  {# 
    Set JsonIgnore for relations
  #}
  {% if field.is_relation %}
  @JsonIgnore
  {# 
    Configure Jackson for required/read_only/write_only
  #}
  {% else %}
  @JsonProperty(value = "{{field.json_key}}"{% if field.is_required %}, required = true{% endif %}{% if field.is_read_only %}, access = JsonProperty.Access.READ_ONLY{% endif %}{% if field.is_write_only %}, access = JsonProperty.Access.WRITE_ONLY{% endif %})
  {% endif %}
  {# 
    Set the Field definition
  #}
  {% if field.is_array and field.is_relation %}
  {{ "private" if encapsulation else "public"}} Set<{{field.type}}> {{field.name}} = new LinkedHashSet<>();
  {% elif field.is_array %}
  {{ "private" if encapsulation else "public"}} List<{{field.type}}> {{field.name}} = new ArrayList<>();
  {% else %}
  {{ "private" if encapsulation else "public"}} {{field.type}} {{field.name}};
  {% endif %}

{% endfor %}

  public static {{model.name}} fromJson(String json) throws Json.JsonException {
    return Json.serializer().fromJson(json, {{model.name}}.class);
  }

}
