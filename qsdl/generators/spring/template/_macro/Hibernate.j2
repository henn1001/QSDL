{# 
  Returns a class identifier.
#}
{% macro attribute_annotation(field) -%}
  {#
    ID
  #}
  {% if field.is_id %}
  @Id
    {% if field.is_read_only %}
  @GeneratedValue(generator="optimized-sequence")
    {% endif %}
  {% endif %}
  {#
    Serialization for objects
  #}
  {% if field.type == "ObjectNode" %}
  @Convert(converter = {{package.util}}.NodeConverter.class)
  @Column(columnDefinition = "text")
  {% endif %}
  {#
    Relations
  #}
  {% if field.is_relation and not field.is_relation_owner %}
      {# 
        the parent side of the relation.
      #}
      {% if field.is_aggregation and field.is_array %}
  @ManyToMany(mappedBy = "{{model.name|lower}}s", fetch = FetchType.LAZY)
      {% elif field.is_aggregation and not field.is_array %}
  @OneToMany(mappedBy = "{{model.name|lower}}s", fetch = FetchType.LAZY)
      {% elif field.is_composition and field.is_array %}
  @OneToMany(mappedBy = "{{model.name|lower}}", fetch = FetchType.LAZY, cascade = CascadeType.ALL)
      {% elif field.is_composition and not field.is_array %}
  @OneToOne(mappedBy = "{{model.name|lower}}", fetch = FetchType.LAZY, cascade = CascadeType.ALL)
      {% endif %}
  {% elif field.is_relation and field.is_relation_owner %}
      {#
        The child/owning side of the relation.
      #}
      {% if field.is_aggregation and field.foreign_key_is_array %}
  @ManyToMany(fetch = FetchType.LAZY)
  @JoinTable(name = "{{field.type|lower}}_to_{{model.name|lower}}", joinColumns = @JoinColumn(name = "{{model.name|lower}}_id"), inverseJoinColumns = @JoinColumn(name = "{{field.type|lower}}_id"))
      {% elif field.is_aggregation and not field.foreign_key_is_array  %}
  @ManyToOne(fetch = FetchType.LAZY)
  @JoinColumn(name = "{{field.type|lower}}_id")
      {% elif field.is_composition and field.foreign_key_is_array %}
  @ManyToOne(fetch = FetchType.LAZY)
  @JoinColumn(name = "{{field.type|lower}}_id")
      {% elif field.is_composition and not field.foreign_key_is_array %}
  @OneToOne(fetch = FetchType.LAZY)
  @JoinColumn(name = "{{field.type|lower}}_id")
      {% endif %}
  {#
    Nested Objects
  #}
  {% elif field.is_array and (field.is_object or field.is_base) %}
  @OneToMany(cascade=CascadeType.ALL, orphanRemoval = true)
  @JoinColumn(name = "{{field.type|lower}}_id")
  {% elif not field.is_array and (field.is_object or field.is_base) %}
  @OneToOne(cascade=CascadeType.ALL, orphanRemoval = true)
  @JoinColumn(name = "{{field.type|lower}}_id")
  {% elif field.is_array %}
  @ElementCollection
  {% endif %}
{% endmacro %}

{# 
  Returns Queries
#}
{%- macro get_query() -%}
{%- for operation in api.operations %}

  {%- if operation.method == "get" and operation.is_pageable and operation.query_parameters %}

    {% for parameter in operation.query_parameters %}
    AND ({{ ":#{#pageable.query['" + parameter.name + "']}" }} IS NULL OR {{ api.name | upper + "." + parameter.name | upper}} = {{ ":#{#pageable.query['" + parameter.name + "']}" }}){{ "\n" if not loop.last }}
    {%- endfor %}

  {%- endif %}
{%- endfor %}
{%- endmacro %}