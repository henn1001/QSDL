{% macro logic(operation) -%}
  {% if operation.method == "get" and operation.is_pageable %}
    {# 
     ########################################################################################
      Get all entities.
    #}
    {% if operation.parent %}
    // confirm existence of parent
    validate{{ operation.path_parameters[0].name | pascal }}({{ operation.path_parameters[0].name }});

    BooleanBuilder predicate = PredicateBuilder.build(queryParameters, {{model.name}}.class);
    predicate.and(Q{{model.name}}.{{model.name|lower}}.{{operation.parent.predicate}}.id.eq({{ operation.path_parameters[0].name }}));
    {% else %}
    BooleanBuilder predicate = PredicateBuilder.build(queryParameters, {{model.name}}.class);
    {% endif %}

    ObjectList ret = {{api.name|lower}}Repository.findAll(predicate, pageable);

    return ret;
  {% elif operation.method == "post" and ( operation.path.endswith('/add') or operation.path.endswith('/remove') ) %}
    {# 
     ########################################################################################
      Create a entity.
    #}
    // get and confirm existence
    // we are not using getById here because somehow the reference does not work when using a public field
    {{ operation.parent.model.name }} {{ operation.parent.model.name|lower }} = {{ operation.parent.model.name|lower }}Repository.findById({{ operation.path_parameters[0].name }})
        .orElseThrow(() -> AppException.entityNotFound({{ operation.parent.model.name }}.class, {{ operation.path_parameters[0].name }}));

    {{ model.name }} {{ model.name|lower }} = {{ model.name|lower }}Repository.findById({{ operation.path_parameters[1].name }})
        .orElseThrow(() -> AppException.entityNotFound({{ model.name }}.class, {{ operation.path_parameters[1].name }}));

    {% if operation.path.endswith('/add') %}
    {{ model.name|lower }}.addTo{{ operation.parent.model.name }}s({{ operation.parent.model.name|lower }});
    {% elif operation.path.endswith('/remove') %}
    {{ model.name|lower }}.removeFrom{{ operation.parent.model.name }}s({{ operation.parent.model.name|lower }});
    {% endif %}

    {{ model.name|lower }}Repository.save({{ model.name|lower }});

    return null;
  {% elif operation.method == "post" %}
    {# 
     ########################################################################################
      Create a entity.
    #}
    {% if operation.parent %}
    // confirm existence of parent
    validate{{ operation.path_parameters[0].name | pascal }}({{ operation.path_parameters[0].name }});

    // add parent relation
    {{ operation.parent.model.name }} {{ operation.parent.model.name|lower }} = {{ operation.parent.model.name|lower }}Repository.getById({{ operation.path_parameters[0].name }});
    {% if encapsulation %}
    body.set{{ operation.parent.model.name }}({{ operation.parent.model.name|lower }});
    {% else %}
    body.{{ operation.parent.model.name|lower }} = {{ operation.parent.model.name|lower }};
    {% endif %}

    {% endif %}
    {{api.name}} ret = {{api.name|lower}}Repository.save(body);

    return ret;
  {% elif operation.method == "get" %}
    {# 
     ########################################################################################
      Get a entity.

    #}
    {% if operation.parent %}
    // confirm existence of parent
    validate{{ operation.path_parameters[0].name | pascal }}({{ operation.path_parameters[0].name }});

    {% endif %}
    {{api.name}} ret = {{api.name|lower}}Repository.find{{ operation.get_repo_by_id_name() }}({{ operation.get_repo_by_id_parameters() }})
        .orElseThrow(() -> AppException.entityNotFound({{api.name}}.class, id));

    return ret;
  {% elif operation.method == "put" %}
    {# 
     ########################################################################################
      Replace entities.
    #}
    {% if operation.parent %}
    // confirm existence of parent
    validate{{ operation.path_parameters[0].name | pascal }}({{ operation.path_parameters[0].name }});

    // add parent relation
    {{ operation.parent.model.name }} {{ operation.parent.model.name|lower }} = {{ operation.parent.model.name|lower }}Repository.getById({{ operation.path_parameters[0].name }});
      {% if encapsulation %}
    body.set{{ operation.parent.model.name }}({{ operation.parent.model.name|lower }});
      {% else %}
    body.{{ operation.parent.model.name|lower }} = {{ operation.parent.model.name|lower }};
      {% endif %}

    {% endif %}
    {{api.name}} dbEntity = {{api.name|lower}}Repository.find{{ operation.get_repo_by_id_name() }}({{ operation.get_repo_by_id_parameters() }})
        .orElseThrow(() -> AppException.entityNotFound({{api.name}}.class, id));

    // update dbEntity with all writeable fields
    dbEntity.replace(body);

    {{api.name}} ret = {{api.name|lower}}Repository.save(dbEntity);

    return ret;
  {% elif operation.method == "patch" %}
    {# 
     ########################################################################################
      Patch entities.
    #}
    {% if operation.parent %}
    // confirm existence of parent
    validate{{ operation.path_parameters[0].name | pascal }}({{ operation.path_parameters[0].name }});

    // add parent relation
    {{ operation.parent.model.name }} {{ operation.parent.model.name|lower }} = {{ operation.parent.model.name|lower }}Repository.getById({{ operation.path_parameters[0].name }});
      {% if encapsulation %}
    body.set{{ operation.parent.model.name }}({{ operation.parent.model.name|lower }});
      {% else %}
    body.{{ operation.parent.model.name|lower }} = {{ operation.parent.model.name|lower }};
      {% endif %}

    {% endif %}
    {{api.name}} dbEntity = {{api.name|lower}}Repository.find{{ operation.get_repo_by_id_name() }}({{ operation.get_repo_by_id_parameters() }})
        .orElseThrow(() -> AppException.entityNotFound({{api.name}}.class, id));

    // update dbEntity with all writeable fields if present
    dbEntity.update(body);

    {{api.name}} ret = {{api.name|lower}}Repository.save(dbEntity);

    return ret;
  {% elif operation.method == "delete" %}
    {# 
     ########################################################################################
      Delete entities.
    #}
    {% if operation.parent %}
    // confirm existence of parent
    validate{{ operation.path_parameters[0].name | pascal }}({{ operation.path_parameters[0].name }});

    {% endif %}
    try {
      {{api.name|lower}}Repository.deleteById({{operation.path_parameters[-1].name}});
    }
    catch (DataRetrievalFailureException e) {
      throw AppException.entityNotFound({{api.name}}.class, id);
    }

    return null;
  {% endif %}
{% endmacro %}